class Propiedad:
    def __init__(self, id_casilla, nombre, precio, renta_base, tipo):
        self.id_casilla = id_casilla
        self.nombre = nombre
        self.precio = precio
        self.renta_base = renta_base
        self.tipo = tipo # 'calle', 'ferrocarril', 'servicio'
        self.dueno = None # Referencia al objeto Jugador

    def tiene_dueno(self):
        return self.dueno is not None


